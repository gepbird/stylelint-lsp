{
  "name": "@gepbird/stylelint-lsp",
  "version": "2.0.1",
  "description": "A stylelint language server",
  "keywords": [
    "stylelint",
    "lsp",
    "language server",
    "multi-root ready"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gepbird/stylelint-lsp"
  },
  "author": "Gutyina Gergő <gutyina.gergo.2@gmail.com>",
  "contributors": [
    "Bob Matcuk <bmatcuk@gmail.com> (https://squeg.net) - original author"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "stylelint-lsp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "prepare": "pnpm clean && pnpm build && husky",
    "test": "jest --coverage",
    "watch": "tsc -w -p tsconfig.build.json"
  },
  "lint-staged": {
    "**/*.{j,t}s?(x)": "eslint --fix"
  },
  "devDependencies": {
    "@types/jest": "~29.5.8",
    "@typescript-eslint/eslint-plugin": "~6.11.0",
    "@typescript-eslint/parser": "~6.11.0",
    "eslint": "~8.54.0",
    "eslint-config-prettier": "~9.0.0",
    "eslint-plugin-jest": "~27.6.0",
    "eslint-plugin-prettier": "~5.0.1",
    "eslint_d": "~13.1.0",
    "husky": "^9.1.7",
    "jest": "~30.4.2",
    "lint-staged": "~17.0.8",
    "prettier": "~3.1.0",
    "ts-jest": "~29.4.11",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "fast-diff": "~1.3.0",
    "resolve-from": "~5.0.0",
    "stylelint": "~16.26.1",
    "vscode-languageserver": "~9.0.1",
    "vscode-languageserver-protocol": "~3.17.5",
    "vscode-languageserver-textdocument": "~1.0.11",
    "vscode-uri": "~3.0.8"
  }
}
