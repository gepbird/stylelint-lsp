{
  "name": "@gepbird/stylelint-lsp",
  "version": "2.0.1",
  "description": "A stylelint language server",
  "keywords": [
    "stylelint",
    "lsp",
    "language server",
    "multi-root ready"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gepbird/stylelint-lsp"
  },
  "author": "Gutyina Gergő <gutyina.gergo.2@gmail.com>",
  "contributors": [
    "Bob Matcuk <bmatcuk@gmail.com> (https://squeg.net) - original author"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "stylelint-lsp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "prepare": "pnpm clean && pnpm build && husky",
    "test": "jest --coverage",
    "watch": "tsc -w -p tsconfig.build.json"
  },
  "lint-staged": {
    "**/*.{j,t}s?(x)": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@types/jest": "~29.5.8",
    "@types/node": "^22.20.0",
    "eslint": "~10.6.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-jest": "~29.15.4",
    "eslint-plugin-prettier": "~5.5.6",
    "eslint_d": "~15.0.2",
    "globals": "~17.7.0",
    "husky": "^9.1.7",
    "jest": "~30.4.2",
    "lint-staged": "~17.0.8",
    "prettier": "~3.1.0",
    "ts-jest": "~29.4.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "~8.63.0"
  },
  "dependencies": {
    "fast-diff": "~1.3.0",
    "resolve-from": "~5.0.0",
    "stylelint": "~17.14.0",
    "vscode-languageserver": "~9.0.1",
    "vscode-languageserver-protocol": "~3.18.2",
    "vscode-languageserver-textdocument": "~1.0.12",
    "vscode-uri": "~3.0.8"
  }
}
